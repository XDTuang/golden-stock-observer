"""
金股观测 — 信号计算引擎 (v2 七信号体系)
========================================
基于公开K线数据（OHLCV），计算以下7个信号：
  1. EMA多周期趋势确认（7/7评分体系）—— 第7信号
  2. 均线多头排列检测（上涨趋势）
  3. 缠论买点近似检测
  4. 金钻信号近似检测（量价配合+阳线）
  5. 机构变红近似检测（价格>WMA20中线）
  6. 老鸭头形态检测（上涨中继形态）—— 新增

信号等级：
  七剑天山(7信号) / 六六大顺(6) / 五福同享(5) / 四喜临门(4)
  / 三线共振(3) / 双线(2) / 单信号(1) / 无信号(0)
"""

from typing import Dict, List, Tuple, Optional
import pandas as pd
import numpy as np
import sys
import os

# RSI 计算：优先复用 wb-finance-skill 的基础指标库（若存在），
# 否则回退到本地纯 pandas 实现。
# 目的：去除对 WorkBuddy 应用包路径的硬依赖——无人值守每日自动化时，
# 应用升级或打包路径变化会导致 import 失败、整条管线崩溃。
try:
    SKILL_SCRIPTS = "/Applications/WorkBuddy.app/Contents/Resources/app.asar.unpacked/resources/builtin-skills/wb-finance-skill/scripts/price-action"
    sys.path.insert(0, SKILL_SCRIPTS)
    from basic_indicators import compute_rsi
except Exception:
    def compute_rsi(series, period: int = 14):
        """Wilder's RSI，纯 pandas 实现（无外部依赖回退）"""
        delta = series.diff()
        gain = delta.clip(lower=0)
        loss = -delta.clip(upper=0)
        avg_gain = gain.ewm(alpha=1.0 / period, adjust=False, min_periods=period).mean()
        avg_loss = loss.ewm(alpha=1.0 / period, adjust=False, min_periods=period).mean()
        rs = avg_gain / avg_loss.replace(0, float("nan"))
        rsi = 100 - 100 / (1 + rs)
        return rsi.fillna(50)


# ─── 1. EMA 计算 ─────────────────────────────────────────────
def compute_ema(series: pd.Series, period: int) -> pd.Series:
    """计算指数移动平均"""
    return series.ewm(span=period, adjust=False).mean()


# ─── 加权20周期均线（牛线1，通达信算法）— 向量化实现 ────────
def weighted_ma_20(series: np.ndarray) -> np.ndarray:
    """
    20日线性递减加权均（通达信 牛线1 算法），向量化实现。

    weights = [20,19,...,1]，对每20日窗口做点积 / 210。
    替代原纯 Python 逐点循环，速度提升约 50–100×（800只×400日场景显著）。
    """
    weights = np.arange(20, 0, -1, dtype=float)  # [20,19,...,1]
    w_sum = float(np.sum(weights))               # 210
    n = len(series)
    result = np.full(n, np.nan)
    if n < 20:
        return result
    windows = np.lib.stride_tricks.sliding_window_view(series, 20)  # (n-19, 20)
    result[19:] = windows @ weights / w_sum
    return result


# ─── 2. EMA 多周期趋势确认（7/7体系） ────────────────────────
def compute_ema_trend_score(df: pd.DataFrame) -> Tuple[int, List[bool], Dict]:
    """
    计算7组EMA三重均线的趋势方向评分。

    EMA分组（从小到大覆盖短中长周期，适配≥200日K线数据）：
      G1: (3, 6, 12)      - 超短线
      G2: (6, 12, 24)     - 短线
      G3: (12, 26, 50)    - 短中线
      G4: (20, 50, 100)   - 中线
      G5: (34, 68, 136)   - 中长线
      G6: (50, 100, 150)  - 长线
      G7: (72, 144, 200)  - 超长线

    每组：short EMA > mid EMA > long EMA → 上升趋势(True)，否则(False)

    Returns:
        (score, group_results, detail)
        score: 0-7 的整数分
        group_results: 7个bool的list，True=该组上升趋势
        detail: 包含各组EMA值的字典
    """
    close = df["close"]
    groups = [
        (3, 6, 12),
        (6, 12, 24),
        (12, 26, 50),
        (20, 50, 100),
        (34, 68, 136),
        (50, 100, 150),
        (72, 144, 200),
    ]

    needs = 200  # 最长EMA周期
    if len(close) < needs:
        return 0, [False] * 7, {}

    group_results = []
    detail = {}

    for s, m, l in groups:
        ema_s = compute_ema(close, s).iloc[-1]
        ema_m = compute_ema(close, m).iloc[-1]
        ema_l = compute_ema(close, l).iloc[-1]
        is_up = bool(ema_s > ema_m > ema_l)
        group_results.append(is_up)
        detail[f"G({s},{m},{l})"] = {
            "ema_short": round(float(ema_s), 2),
            "ema_mid": round(float(ema_m), 2),
            "ema_long": round(float(ema_l), 2),
            "up": is_up,
        }

    score = sum(group_results)
    return score, group_results, detail


# ─── 3. 均线多头排列检测（上涨趋势信号） ─────────────────────
def check_ma_bullish_alignment(df: pd.DataFrame) -> Tuple[bool, Dict]:
    """
    检测均线多头排列：MA5 > MA10 > MA20 > MA60
    或者金叉启动：MA5上穿MA20 且 MA10 > MA20
    或者主升强势：MA5 > MA10 > MA20 且 价格在MA5上方

    Returns:
        (is_uptrend, detail)
    """
    close = df["close"]

    if len(close) < 60:
        return False, {"reason": "数据不足60日"}

    ma5 = close.rolling(5).mean()
    ma10 = close.rolling(10).mean()
    ma20 = close.rolling(20).mean()
    ma60 = close.rolling(60).mean()

    last_idx = -1
    c = close.iloc[last_idx]
    m5, m10, m20, m60 = ma5.iloc[last_idx], ma10.iloc[last_idx], ma20.iloc[last_idx], ma60.iloc[last_idx]

    # 条件1：完全多头排列
    full_bullish = bool(m5 > m10 > m20 > m60)

    # 条件2：金叉启动已移除（过于宽松，几乎所有轻微反弹都会触发）
    # golden_cross 不再作为上涨趋势的判定条件

    # 条件3：主升强势
    strong_bullish = bool(c > m5 > m10 > m20)

    # 仅保留两个严格条件：完全多头排列 或 主升强势（移除过于宽松的金叉启动）
    is_uptrend = full_bullish or strong_bullish

    return is_uptrend, {
        "ma5": round(float(m5), 2),
        "ma10": round(float(m10), 2),
        "ma20": round(float(m20), 2),
        "ma60": round(float(m60), 2) if not pd.isna(m60) else None,
        "full_bullish": full_bullish,
        "strong_bullish": strong_bullish,
    }


# ─── TDX 缠论辅助函数 ─────────────────────────────────────────
def _tdx_backset(condition: np.ndarray, n: int) -> np.ndarray:
    """通达信 BACKSET(X,N): 若X[i]为真，则将X[i-N+1]到X[i]全部设为真"""
    result = condition.copy()
    for i in range(len(condition)):
        if condition[i]:
            start = max(0, i - n + 1)
            result[start:i + 1] = True
    return result


def _tdx_barslast(condition: np.ndarray) -> np.ndarray:
    """通达信 BARSLAST(X): 上一次X为真到当前的周期数"""
    result = np.zeros(len(condition), dtype=int)
    last = -1
    for i in range(len(condition)):
        if condition[i]:
            last = i
        result[i] = i - last if last >= 0 else 99999
    return result


def _tdx_lowrange(series: np.ndarray) -> np.ndarray:
    """通达信 LOWRANGE(L): 向前连续最低价的周期数（包含当前K线）"""
    n = len(series)
    result = np.ones(n, dtype=int)
    for i in range(1, n):
        if series[i - 1] >= series[i]:
            result[i] = result[i - 1] + 1
    return result


def _tdx_toprange(series: np.ndarray) -> np.ndarray:
    """通达信 TOPRANGE(H): 向前连续最高价的周期数（包含当前K线）"""
    n = len(series)
    result = np.ones(n, dtype=int)
    for i in range(1, n):
        if series[i - 1] <= series[i]:
            result[i] = result[i - 1] + 1
    return result


def _tdx_raw_pivots(high: np.ndarray, low: np.ndarray) -> tuple:
    """
    通达信原始局部高低点预选（5周期BACKSET逻辑）。

    返回 (high_C, low_C):
      high_C[i] = 1  → 局部高点候选
      low_C[i]  = -1 → 局部低点候选
    """
    n = len(high)

    # ── 局部低点预选 ──
    # LLV(L,5) < REF(LLV(L,4),1)
    llv5 = np.array([np.min(low[max(0, i - 4):i + 1]) for i in range(n)])
    llv4_raw = np.zeros(n)
    for i in range(3, n):
        llv4_raw[i] = np.min(low[i - 3:i + 1])
    llv4_ref = np.roll(llv4_raw, 1)
    low_A = _tdx_backset(llv5 < llv4_ref, 4)
    low_B = _tdx_backset(~low_A & np.roll(low_A, 1), 2)
    low_C = np.zeros(n, dtype=int)
    for i in range(1, n):
        if low_B[i] and not low_B[i - 1]:
            low_C[i] = -1

    # ── 局部高点预选 ──
    hhv5 = np.array([np.max(high[max(0, i - 4):i + 1]) for i in range(n)])
    hhv4_raw = np.zeros(n)
    for i in range(3, n):
        hhv4_raw[i] = np.max(high[i - 3:i + 1])
    hhv4_ref = np.roll(hhv4_raw, 1)
    high_A = _tdx_backset(hhv5 > hhv4_ref, 4)
    high_B = _tdx_backset(~high_A & np.roll(high_A, 1), 2)
    high_C = np.zeros(n, dtype=int)
    for i in range(1, n):
        if high_B[i] and not high_B[i - 1]:
            high_C[i] = 1

    return high_C, low_C


def _tdx_gap(high: np.ndarray, low: np.ndarray) -> np.ndarray:
    """缺口判断: 1=向上跳空, -1=向下跳空, 0=无缺口"""
    n = len(high)
    gap = np.zeros(n, dtype=int)
    for i in range(1, n):
        if low[i] > high[i - 1]:
            gap[i] = 1
        elif high[i] < low[i - 1]:
            gap[i] = -1
    return gap


def _tdx_filter_pivots(high_piv: np.ndarray, low_piv: np.ndarray,
                        high: np.ndarray, low: np.ndarray,
                        gap: np.ndarray) -> tuple:
    """
    通达信单层分型枢轴过滤 — 确认高低点交替成立。

    核心逻辑（对应 TDX 中 高保留A/B/判断 和 低保留A/B/判断A）：
    - 高点必须跟随一个有效低点，且价格突破前低
    - 低点必须跟随一个有效高点，且价格跌破前高
    - 通过缺口过滤和范围比较排除假突破
    """
    n = len(high)
    bars_high = _tdx_barslast(high_piv == 1)
    bars_low = _tdx_barslast(low_piv == -1)
    top_r = _tdx_toprange(high)
    low_r = _tdx_lowrange(low)

    new_high = np.zeros(n, dtype=int)
    new_low = np.zeros(n, dtype=int)

    for i in range(n):
        # ═══ 过滤高点 ═══
        if high_piv[i] == 1:
            bh = int(bars_high[i])
            bl = int(bars_low[i])

            # 高保留A: 前低比前高更远 → 验证创新高+突破前低
            if bl > bh:
                if bl < n and i - bl - 1 >= 0:
                    win = high[max(0, i - bl - 1):i + 1]
                    prev = high[max(0, i - bl - 2):i]
                    if len(win) > 0 and len(prev) > 0:
                        if np.max(win) > np.max(prev) and high[i] > low[i - bl - 1]:
                            new_high[i] = 1

            # 高保留B + 判断: 前低更近 → 多重条件确认
            else:
                # 高保留B: 前低已保留 + 缺口/距离 + 价格突破
                if bl < n and i - bl - 1 >= 0:
                    prev_low_ok = (low_piv[i - bl - 1] == -1)
                    gap_ok = (bl >= 4 or np.max(gap[max(0, i - bl):i + 1]) == 1)
                    if prev_low_ok and gap_ok and high[i] > low[i - bl - 1]:
                        new_high[i] = 1

                # 判断: 预判条件 + 范围比较
                if new_high[i] != 1:
                    yp = True  # 预判
                    if bl < 4 and np.max(gap[max(0, i - bl):i + 1]) != 1:
                        yp = False
                    elif bl < n and i - bl - 1 >= 0 and low_piv[i - bl - 1] == 0:
                        yp = False
                    if yp:
                        tr = int(top_r[i])
                        lr1 = int(low_r[i - bl - 1]) if i - bl - 1 >= 0 else 0
                        lr2 = int(low_r[i - bl]) if i - bl >= 0 else 0
                        tr_ref = int(top_r[i - bh]) if i - bh >= 0 else 0
                        if tr > lr1 and tr > lr2 and tr > tr_ref:
                            new_high[i] = 1

        # ═══ 过滤低点 ═══
        if low_piv[i] == -1:
            bh = int(bars_high[i])
            bl = int(bars_low[i])

            # 低保留A: 前高比前低更远 → 验证创新低+跌破前高
            if bh > bl:
                if bh < n and i - bh - 1 >= 0:
                    win = low[max(0, i - bh - 1):i + 1]
                    prev = low[max(0, i - bh - 2):i]
                    if len(win) > 0 and len(prev) > 0:
                        if np.min(win) < np.min(prev) and low[i] < high[i - bh - 1]:
                            new_low[i] = -1

            # 低保留B + 判断A: 前高更近 → 多重条件确认
            else:
                # 低保留B: 前高已保留 + 缺口/距离 + 价格跌破
                if bh < n and i - bh - 1 >= 0:
                    prev_high_ok = (high_piv[i - bh - 1] == 1)
                    gap_ok = (bh >= 4 or np.min(gap[max(0, i - bh):i + 1]) == -1)
                    if prev_high_ok and gap_ok and low[i] < high[i - bh - 1]:
                        new_low[i] = -1

                # 判断A: 预判 + 范围比较
                if new_low[i] != -1:
                    yp = True  # 预判A
                    if bh < 4 and np.min(gap[max(0, i - bh):i + 1]) != -1:
                        yp = False
                    elif bh < n and i - bh - 1 >= 0 and high_piv[i - bh - 1] == 0:
                        yp = False
                    if yp:
                        lr = int(low_r[i])
                        tr1 = int(top_r[i - bh - 1]) if i - bh - 1 >= 0 else 0
                        tr2 = int(top_r[i - bh]) if i - bh >= 0 else 0
                        lr_ref = int(low_r[i - bl]) if i - bl >= 0 else 0
                        if lr > tr1 and lr > tr2 and lr > lr_ref:
                            new_low[i] = -1

    return new_high, new_low


def _tdx_aaad_merge(high_piv: np.ndarray, low_piv: np.ndarray,
                     high: np.ndarray, low: np.ndarray) -> np.ndarray:
    """
    AAAD 冲突合并 → 极点保留。

    若同一K线同时出现高低点冲突，按前次极点级别判定：
    - 当前高点 > 前次高点 → 判定为卖点(1)
    - 当前低点 < 前次低点 → 判定为买点(-1)
    - 否则默认为高低点叠加（多数情况不会冲突）

    返回 final[i] ∈ {-1(买), 0(无), 1(卖)}
    """
    n = len(high)
    bars_high = _tdx_barslast(high_piv == 1)
    bars_low = _tdx_barslast(low_piv == -1)

    final = np.zeros(n, dtype=int)
    for i in range(n):
        if high_piv[i] == 1 and low_piv[i] == -1:
            bh = int(bars_high[i])
            bl = int(bars_low[i])
            h_ref = i - bh - 2
            l_ref = i - bl - 2
            if h_ref >= 0 and high[i] > high[h_ref]:
                final[i] = 1
            elif l_ref >= 0 and low[i] < low[l_ref]:
                final[i] = -1
        else:
            final[i] = high_piv[i] + low_piv[i]  # 1(卖) 或 -1(买) 或 0(无)

    return final


# ─── 4. 缠论买字检测（通达信源码·三层分型枢轴） ───────────────
def check_chan_buy_signal(df: pd.DataFrame) -> Tuple[bool, Dict]:
    """
    缠论买字检测 — 基于通达信源码的三层分型枢轴确认系统。

    核心算法：
      1. 5周期BACKSET局部高低点预选（对标TDX 局部低点预选C/局部高点预选C）
      2. 三层交替枢轴确认 — 每层验证高低点交替、价格突破、缺口过滤
      3. AAAD冲突合并 → 极点保留（-1=买, 1=卖）

    判定条件：
      最近2个交易日内出现"买"信号（极点保留=-1）。
      对标通达信: DRAWTEXT(极点保留=-1, 局部极点, '买')

    Returns:
        (is_buy, detail)
    """
    close = df["close"].values.astype(float)
    high = df["high"].values.astype(float)
    low = df["low"].values.astype(float)
    n = len(close)

    if n < 60:
        return False, {"reason": "数据不足60日"}

    # Step 1: 原始局部高低点预选（TDX 5周期BACKSET逻辑）
    raw_high, raw_low = _tdx_raw_pivots(high, low)

    # Step 2: 缺口判断
    gap_arr = _tdx_gap(high, low)

    # Step 3: 三层分型枢轴过滤（逐步确认真实高低点交替结构）
    pivots_high, pivots_low = raw_high.copy(), raw_low.copy()
    for level in range(3):
        pivots_high, pivots_low = _tdx_filter_pivots(
            pivots_high, pivots_low, high, low, gap_arr
        )

    # Step 4: AAAD冲突合并 → 极点保留
    final = _tdx_aaad_merge(pivots_high, pivots_low, high, low)

    # Step 5: 检查近2个交易日内是否有"买"（极点保留=-1）
    CHECK_DAYS = 2
    check_window = min(CHECK_DAYS, n)
    has_buy = (-1 in final[-check_window:])

    if not has_buy:
        recent_buy_count = int(np.sum(final[-60:] == -1))
        recent_sell_count = int(np.sum(final[-60:] == 1))
        return False, {
            "reason": f"近{CHECK_DAYS}个交易日内未出现缠论买点",
            "recent_buy_pivots": recent_buy_count,
            "recent_sell_pivots": recent_sell_count,
        }

    # 找到最近一个买点
    buy_idx = None
    for i in range(n - 1, max(-1, n - 1 - CHECK_DAYS), -1):
        if final[i] == -1:
            buy_idx = i
            break

    buy_price = float(low[buy_idx])
    days_ago = n - 1 - buy_idx
    buy_date = str(df.index[buy_idx])[:10]

    # 最近的卖点（上极值参考，用于衡量反弹空间）
    sell_idx = None
    sell_price = None
    for i in range(n - 1, max(-1, n - 60), -1):
        if final[i] == 1:
            sell_idx = i
            sell_price = float(high[i])
            break

    recent_pivots = int(np.sum(np.abs(final[-60:]) > 0))
    buy_pivots = int(np.sum(final[-60:] == -1))
    sell_pivots = int(np.sum(final[-60:] == 1))

    return True, {
        "buy_date": buy_date,
        "buy_price": round(buy_price, 2),
        "days_ago": days_ago,
        "sell_ref": round(sell_price, 2) if sell_price else None,
        "sell_date": str(df.index[sell_idx])[:10] if sell_idx else None,
        "recent_pivots_60d": recent_pivots,
        "buy_pivots_60d": buy_pivots,
        "sell_pivots_60d": sell_pivots,
    }


# ─── 4b. XMA 计算（通达信 XMA 严格实现） ─────────────────────
def compute_xma(series: pd.Series, period: int = 25) -> pd.Series:
    """
    计算通达信 XMA（居中对称移动平均）—— 与通达信自带 XMA 严格对齐。

    TDX 的 XMA 本质是以当前 K 线为中心的对称移动平均（未来函数）：
    计算第 i 根时取 [i-period//2, i+period//2] 窗口（边界裁剪）的
    简单平均。window 长度≈period（奇数），与 XMA(X,N) 语义一致。

    实现：pandas rolling(period, center=True, min_periods=1) 即该居中窗口，
    边界处用可用数据（min_periods=1），与 TDX 边界行为一致。

    重要：旧的 DEMA 近似（2*EMA-EMA(EMA)）带滞后，导致 金牛/金钻趋势
    轨位整体偏移，H<金牛 / L<金钻趋势 在边界股上被错误判定（2026-07-11 已校验，
    33 只假阳性主因）。换成居中 XMA 后轨位与 TDX 实盘吻合。
    """
    return series.rolling(period, center=True, min_periods=1).mean()


# ─── 4c. DDX 大单动向计算 ────────────────────────────────────
def compute_ddx(df: pd.DataFrame) -> pd.Series:
    """
    计算通达信 DDX（大单动向）指标近似值。

    算法（CAPITAL=0 分支，全A通用）：
      JJ  = (H+L+C)/3                         — 典型价格
      QJ0 = V / IF(H=L, 4, H-L)              — 单位价格区间的成交量
      QJ1 = QJ0 * (JJ - MIN(C,O))             — 下半实体区量
      QJ2 = QJ0 * (MIN(O,C) - L)              — 下影线区量
      QJ3 = QJ0 * (H - MAX(O,C))              — 上影线区量
      QJ4 = QJ0 * (MAX(C,O) - JJ)             — 上半实体区量
      DDX = ((QJ1+QJ2) - (QJ3+QJ4)) / 10000   — 净买量（正值=主力买入）

    注：为适配A股实际成交量级，DDX 进一步归一化为成交量占比：
      DDX_norm = DDX_raw / max(V, 1) * 100 = 净买占比(%)

    Returns:
        DDX 序列（pd.Series），归一化到 [-100, 100] 百分比范围
    """
    high = df["high"]
    low = df["low"]
    close = df["close"]
    open_p = df["open"]
    vol = df.get("volume", df.get("vol", pd.Series([1.0] * len(close))))

    jj = (high + low + close) / 3.0
    hl_range = (high - low).replace(0, 4)  # IF(H=L, 4, H-L)
    qj0 = vol / hl_range

    min_co = pd.concat([close, open_p], axis=1).min(axis=1)
    max_co = pd.concat([close, open_p], axis=1).max(axis=1)

    qj1 = qj0 * (jj - min_co)    # 下半实体
    qj2 = qj0 * (min_co - low)   # 下影线
    qj3 = qj0 * (high - max_co)  # 上影线
    qj4 = qj0 * (max_co - jj)    # 上半实体

    ddx_raw = ((qj1 + qj2) - (qj3 + qj4)) / 10000.0
    # 归一化：净买量 / 总成交量 * 100 → 百分比
    ddx = (ddx_raw / vol.replace(0, 1)) * 100.0
    return ddx


# ─── 5. 金钻选股（严格基于通达信源码） ────────────────────────
def check_golden_diamond(df: pd.DataFrame) -> Tuple[str, Dict]:
    """
    金钻选股 — 严格基于通达信源码，逐条件对标。

    两条独立路径，满足任一即触发：

    路径A — 主力信号（最近1个交易日）:
      ① 金钻起涨 (XG2): 阳线 + DY2<0.02 + MA5>MA60 + 涨幅≥2% + H<金牛
      ② 买入 (XG):   金钻趋势>HIGH + 回调买 + L<=金钻趋势
         回调买 = LLV(VAR23,2)==LLV(VAR23,7) AND COUNT(VAR23<0,2)
                 AND CROSS(VAR23, MA(VAR23,2))

    路径B — 趋势辅助信号（红区黄柱，捕捉筑底后起涨）:
      前置条件（用户校正 2026-07-09）：含当日收盘在内的最近 5 个连续交易日内，
      至少连续 3 天为「红区黄柱日」即触发：
        红区 = 金钻趋势 > 金牛2          (DRAWBAND 红色带覆盖区域)
        黄柱 = 金钻趋势 > LOW            (STICKLINE COLORYELLOW 触发：
              金钻趋势>LOW 时 A/B/C/D 四条 STICKLINE 至少一条成立，
              即日线柱状图出现黄柱)
        红区黄柱日 = 红区 AND 黄柱（黄柱落在红色带覆盖范围内）
      信号 N = 自最新日向前连续红区黄柱天数；若当日非红区黄柱但窗口内仍有
              ≥3 连续段，则 N 取窗口内最长连续段。
      该信号用于补捕获「严格 XG/XG2 不触发、但近期已连续筑底企稳」的起涨股。

    核心指标：
      金钻趋势 = 2*XMA(XMA(L,25),25) - XMA(XMA(H,25),25)    — 下轨
      金牛     = 2*XMA(XMA(H,25),25) - XMA(XMA(L,25),25)    — 上轨
      金牛2    = EMA(金钻趋势, 25)                          — 红区判定线
      VAR23    = 100*XMA2(delta_C,6) / XMA2(|delta_C|,6)    — 趋势强度

    Returns:
        (signal_type, detail)
        信号类型: "金钻起涨" / "买入" / "红区黄柱连续Nd日" / ""
    """
    close = df["close"]
    open_p = df["open"]
    high = df["high"]
    low = df["low"]
    vol = df.get("volume", df.get("vol", pd.Series([1] * len(close))))
    n = len(close)

    if n < 70:
        return "", {"reason": "数据不足70日"}

    # ═══════════════════════════════════════════════════════════
    # 预计算全序列指标（对标通达信源码）
    # ═══════════════════════════════════════════════════════════

    # 金牛 / 金钻趋势 / 金牛2
    xma_h_25 = compute_xma(high, 25)
    xma_l_25 = compute_xma(low, 25)
    xma2_h = compute_xma(xma_h_25, 25)
    xma2_l = compute_xma(xma_l_25, 25)
    golden_bull = 2.0 * xma2_h - xma2_l          # 金牛（上轨）
    golden_trend = 2.0 * xma2_l - xma2_h          # 金钻趋势（下轨）
    gt2_ema = compute_ema(golden_trend, 25)       # 金牛2（红区判定线）

    # DDX（通达信原版，绝对量）— 对标源码 DDX:=((QJ1+QJ2)-(QJ3+QJ4))/IF(CAPITAL=0,10000,10000)
    # 数据源 VOL 单位为「手」，净买手数通常数千级，/10000 后 DDX 量级≈±0.5，
    # 与通达信一致，使 V2/DY2 量级正确（DY2<0.02 = 前日资金净流入≈0 的语义）。
    # 注意：不可归一化为百分比，否则 V2 量级±数、DY2<0.02 几乎永不满足 → 金钻起涨漏触发。
    jj = (high + low + close) / 3.0
    hl_range = (high - low).replace(0, 4)
    qj0 = vol / hl_range
    min_co = pd.concat([close, open_p], axis=1).min(axis=1)
    max_co = pd.concat([close, open_p], axis=1).max(axis=1)
    qj1 = qj0 * (jj - min_co)
    qj2 = qj0 * (min_co - low)
    qj3 = qj0 * (high - max_co)
    qj4 = qj0 * (max_co - jj)
    ddx_pct = ((qj1 + qj2) - (qj3 + qj4)) / 10000.0   # 通达信 DDX（手/万手单位，非百分比）

    # V2 = SMA(IF(C>=REF(C,1), DDX, -DDX/100), 2, 1) — SMA(X,2,1) = (X + prev)/2
    v2 = np.zeros(n, dtype=float)
    for i in range(1, n):
        adj = ddx_pct.iloc[i] if close.iloc[i] >= close.iloc[i - 1] else -ddx_pct.iloc[i] / 100.0
        v2[i] = (adj + v2[i - 1]) / 2.0          # SMA(X,2,1) = mean of adj and prev

    # MA5 / MA60
    ma5 = close.rolling(5).mean()
    ma60 = close.rolling(60).mean()

    # VAR23 = 100 * XMA2(delta_C, 6) / XMA2(|delta_C|, 6)
    chg_1d = close.diff()
    xma_chg_abs = compute_xma(compute_xma(chg_1d.abs(), 6), 6)
    xma_chg_raw = compute_xma(compute_xma(chg_1d, 6), 6)
    var23 = 100.0 * xma_chg_raw / xma_chg_abs.replace(0, np.nan)

    # MA(VAR23, 2) — VAR23的2日简单移动平均（用于CROSS判定）
    var23_ma2 = var23.rolling(2).mean()

    # ═══════════════════════════════════════════════════════════
    # 路径A：最近1个交易日的单点主力信号
    # ═══════════════════════════════════════════════════════════
    idx = n - 1
    c = float(close.iloc[idx]); o = float(open_p.iloc[idx])
    h = float(high.iloc[idx]); l = float(low.iloc[idx])
    prev_c = float(close.iloc[idx - 1]) if idx > 0 else c

    gb_val = float(golden_bull.iloc[idx])
    gt_val = float(golden_trend.iloc[idx])
    gt2_val = float(gt2_ema.iloc[idx])
    ma5_val = float(ma5.iloc[idx])
    ma60_val = float(ma60.iloc[idx])
    pct_chg = (c / prev_c - 1.0) * 100
    is_yang = c > o

    # ── DY2 ──
    # DY = CURRBARSCOUNT=1 AND C<REF(C,1) → 仅最新K线(最后一根)且下跌时为1
    dy = 1.0 if (idx == n - 1 and c < prev_c) else 0.0
    dy2 = float(v2[idx - 1]) - dy if idx >= 1 else 0.0

    # ── 红区/黄柱状态（仅可视化，不作选股门槛）──
    # 通达信源码 XG(买入)、XG2(金钻起涨) 均不含 DDX>0 或红区限制；
    # DRAWBAND 红色带 = 金钻趋势>金牛2，STICKLINE 黄柱 = 金钻趋势落在K线内，
    # 二者仅用于界面呈现，不参与选股判定。
    ddx_last = float(ddx_pct.iloc[idx])
    in_red_zone = gt_val > gt2_val   # 仅"金钻趋势在金牛2上方"的红色带状态

    # ── ① 金钻起涨 (XG2) — 严格对标通达信源码 ──
    #    源码: XG2:=C>O AND DY2<0.02 AND MA(C,5)>MA(C,60) AND C/REF(C,1)>=1.02 AND H<金牛
    #          DRAWTEXT(XG2 AND L<金钻趋势, L, '金钻起涨')
    #    完整触发 = XG2 且 L<金钻趋势（通达信以 AND 叠加为画字条件）。
    xg2_hit = (
        is_yang and dy2 < 0.02 and ma5_val > ma60_val
        and pct_chg >= 2.0 and h < gb_val and l < gt_val
    )

    # ── ② 买入 (XG) — 回调买三条件 ──
    # 强制门槛: 必须在红区 + 收盘价不能远低于金钻趋势
    # 条件: 金钻趋势 > HIGH + 回调买 + L <= 金钻趋势
    gt_above_high = gt_val > h
    low_touch_gt = l <= gt_val

    # 回调买 = LLV(VAR23,2)==LLV(VAR23,7) AND COUNT(VAR23<0,2) AND CROSS(VAR23,MA2)
    var_last = float(var23.iloc[idx]) if not np.isnan(var23.iloc[idx]) else 0.0
    var_prev = float(var23.iloc[idx - 1]) if idx >= 1 and not np.isnan(var23.iloc[idx - 1]) else 0.0
    var_pprev = float(var23.iloc[idx - 2]) if idx >= 2 and not np.isnan(var23.iloc[idx - 2]) else 0.0
    var_ma2_last = float(var23_ma2.iloc[idx]) if not np.isnan(var23_ma2.iloc[idx]) else 0.0
    var_ma2_prev = float(var23_ma2.iloc[idx - 1]) if idx >= 1 and not np.isnan(var23_ma2.iloc[idx - 1]) else 0.0

    # LLV(VAR23, 2) == LLV(VAR23, 7)
    llv2 = min(var_last, var_prev)
    if idx >= 6:
        llv7 = float(var23.iloc[idx - 6:idx + 1].min())
    else:
        llv7 = float(var23.iloc[max(0, idx - 6):idx + 1].min())

    # COUNT(VAR23<0, 2): 近2日至少1日 VAR23<0
    count_var23_neg_2 = (1 if var_prev < 0 else 0) + (1 if var_last < 0 else 0)

    # CROSS(VAR23, MA(VAR23,2)): 上穿
    cross_var23_ma2 = var_prev <= var_ma2_prev and var_last > var_ma2_last

    callback_buy = (
        abs(llv2 - llv7) < 1e-8          # LLV2 == LLV7（低点在近2日形成）
        and count_var23_neg_2 >= 1       # COUNT(VAR23<0, 2)
        and cross_var23_ma2               # CROSS(VAR23, MA2)
    )

    xg_hit = (
        gt_above_high and callback_buy and low_touch_gt
    )

    # ═══════════════════════════════════════════════════════════
    # 路径B：红区黄柱（辅助参考信号，捕捉筑底后起涨）
    #   红区   = 金钻趋势 > 金牛2   (DRAWBAND 红色带覆盖区域)
    #   黄柱   = 金钻趋势 > LOW     (STICKLINE COLORYELLOW 触发：
    #            金钻趋势>LOW 时 A/B/C/D 四条 STICKLINE 至少一条成立，
    #            即日线柱状图出现黄柱)
    #   红区黄柱日 = 红区 AND 黄柱（黄柱落在红色带覆盖范围内）
    #   前置条件（用户校正 2026-07-09，严格模式 2026-07-10）：连续段必须
    #     *结束于当日*（即今日收盘仍为红区黄柱日），且自最新日向前连续 ≥HZ_MIN 天，
    #     方触发辅助信号。窗口 HZ_WINDOW 仅用于详情展示，不再作为触发回退条件。
    #   信号 N = 自最新日向前连续红区黄柱天数（hz_streak）。
    # ═══════════════════════════════════════════════════════════
    HZ_WINDOW = 5          # 最近5个连续交易日（含当日）
    HZ_MIN = 3             # 窗口内至少连续3天
    hz_streak = 0
    red_zone_hz_days = []
    # 回看窗口：至少覆盖要求天数 + 余量，用于详情展示
    hz_lookback = min(n, HZ_WINDOW + 10)
    for di in range(n - hz_lookback, n):
        ci = float(close.iloc[di]); oi = float(open_p.iloc[di])
        hi = float(high.iloc[di]); li = float(low.iloc[di])

        gt_i = float(golden_trend.iloc[di])
        gt2_i = float(gt2_ema.iloc[di])

        # 红区 = 金钻趋势 > 金牛2（DRAWBAND 红色带覆盖区域）
        red_zone = gt_i > gt2_i
        # 黄柱 = 金钻趋势 > LOW × 1.025（STICKLINE COLORYELLOW 触发，
        #         安全边距 2.5% 过滤 XMA 近似导致的边界 case 误标）
        _YELLOW_MARGIN = 1.025
        yellow_bar = gt_i > li * _YELLOW_MARGIN
        # 红区黄柱 = 红区 AND 黄柱（黄柱落在红色带覆盖范围内）
        is_red_yellow = red_zone and yellow_bar

        red_zone_hz_days.append({
            "idx": di,
            "date": str(df.index[di].strftime("%Y-%m-%d")) if hasattr(df.index[di], 'strftime') else str(df.index[di]),
            "red_zone": red_zone,
            "yellow_bar": yellow_bar,
            "is_red_yellow": is_red_yellow,
            "golden_trend": round(gt_i, 2),
            "golden_bull2": round(gt2_i, 2),
            "close": round(ci, 2),
            "high": round(hi, 2),
            "low": round(li, 2),
        })

    # 自最新交易日向前回数连续红区黄柱日（带安全边距）
    _YM = 1.025
    for di in range(n - 1, -1, -1):
        gt_i = float(golden_trend.iloc[di])
        gt2_i = float(gt2_ema.iloc[di])
        li = float(low.iloc[di])
        if gt_i > gt2_i and gt_i > li * _YM:
            hz_streak += 1
        else:
            break

    # 前置条件：含当日收盘在内的最近 HZ_WINDOW 个连续交易日内，至少连续 HZ_MIN 天红区黄柱
    window_start = max(0, n - HZ_WINDOW)
    window_flags = []
    for di in range(window_start, n):
        gt_i = float(golden_trend.iloc[di]); gt2_i = float(gt2_ema.iloc[di]); li = float(low.iloc[di])
        window_flags.append(gt_i > gt2_i and gt_i > li * _YM)
    # 窗口内最长连续 True 子串
    hz_window_run = 0; _cur = 0
    for f in window_flags:
        _cur = _cur + 1 if f else 0
        hz_window_run = max(hz_window_run, _cur)
    # 信号 N：取自最新日向前连续天数（严格模式：连续段必须结束于当日）
    hz_report = hz_streak
    hz_recent_ok = hz_streak >= HZ_MIN

    # ═══════════════════════════════════════════════════════════
    # 信号判定（三子形态，与 golden_diamond_scan.py / 通达信源码一致）
    #
    # 策略锁定(2026-07-11): 金钻选股三子形态，复用验证版引擎（居中XMA）。
    #   优先级: 金钻起涨 > 买入 > 红区黄柱连续
    #   ① 金钻起涨(XG2): 阳线 + DY2<0.02 + MA5>MA60 + 涨幅≥2% + H<金牛 + 回踩L<金钻趋势
    #   ② 买入(XG):      金钻趋势>HIGH + 回调买(LLV/CROSS) + L<=金钻趋势
    #   ③ 红区黄柱连续:   金钻趋势>金牛2 且 金钻趋势>最低价×1.025，最近5日窗口连续≥3日
    # XG2/XG 检查最近2个交易日窗口（含当日），与 TDX 标记可见性一致。
    # ═══════════════════════════════════════════════════════════
    def eval_bar(di):
        """单根K线主力信号判定（对标 TDX，含 L<金钻趋势）。返回 (xg2, xg)。"""
        if di < 1:
            return False, False
        ci = float(close.iloc[di]); oi = float(open_p.iloc[di])
        hi = float(high.iloc[di]); li = float(low.iloc[di])
        gb_i = float(golden_bull.iloc[di]); gt_i = float(golden_trend.iloc[di])
        m5_i = float(ma5.iloc[di]); m60_i = float(ma60.iloc[di])
        prev_ci = float(close.iloc[di - 1])
        pct_i = (ci / prev_ci - 1.0) * 100
        yang_i = ci > oi
        dy_i = 1.0 if (di == n - 1 and ci < prev_ci) else 0.0
        dy2_i = float(v2[di - 1]) - dy_i
        xg2 = (yang_i and dy2_i < 0.02 and m5_i > m60_i
               and pct_i >= 2.0 and hi < gb_i and li < gt_i)
        # 买入(XG): 金钻趋势>HIGH + 回调买 + L<=金钻趋势
        gt_above = gt_i > hi
        low_touch = li <= gt_i
        vL = float(var23.iloc[di]) if not np.isnan(var23.iloc[di]) else 0.0
        vP = float(var23.iloc[di - 1]) if di >= 1 and not np.isnan(var23.iloc[di - 1]) else 0.0
        m2L = float(var23_ma2.iloc[di]) if not np.isnan(var23_ma2.iloc[di]) else 0.0
        m2P = float(var23_ma2.iloc[di - 1]) if di >= 1 and not np.isnan(var23_ma2.iloc[di - 1]) else 0.0
        llv2 = min(vL, vP)
        if di >= 6:
            llv7 = float(var23.iloc[di - 6:di + 1].min())
        else:
            llv7 = float(var23.iloc[max(0, di - 6):di + 1].min())
        cnt = (1 if vP < 0 else 0) + (1 if vL < 0 else 0)
        cross = vP <= m2P and vL > m2L
        cb = abs(llv2 - llv7) < 1e-8 and cnt >= 1 and cross
        xg = gt_above and cb and low_touch
        return xg2, xg

    win_start = max(1, n - 2)
    result_signal = ""
    trigger_idx = None
    # 优先 金钻起涨
    for di in range(win_start, n):
        xg2_d, _ = eval_bar(di)
        if xg2_d:
            result_signal = "金钻起涨"; trigger_idx = di; break
    # 其次 买入
    if not result_signal:
        for di in range(win_start, n):
            _, xg_d = eval_bar(di)
            if xg_d:
                result_signal = "买入"; trigger_idx = di; break
    # 再次 红区黄柱连续
    if not result_signal and hz_recent_ok:
        result_signal = f"红区黄柱连续{hz_report}日"
        trigger_idx = n - 1

    if not result_signal:
        return "", {
            "reason": "近2日无主力信号(金钻起涨/买入)且未连续≥3日红区黄柱",
            "hz_streak": hz_streak,
            "hz_window_run": hz_window_run,
            "hz_window": HZ_WINDOW,
            "hz_min": HZ_MIN,
            "hz_recent_ok": hz_recent_ok,
            "red_zone_hz_days": red_zone_hz_days,
        }

    # ═══════════════════════════════════════════════════════════
    # 构建详情
    # ═══════════════════════════════════════════════════════════
    signal_date = (str(df.index[trigger_idx].strftime("%Y-%m-%d"))
                    if hasattr(df.index[trigger_idx], 'strftime') else str(df.index[trigger_idx]))

    detail = {
        "signal_date": signal_date,
        "days_ago": 0,
        "signal_type": result_signal,
        "days_ago": (n - 1 - trigger_idx) if trigger_idx is not None else 0,
        # 红区黄柱状态（可视化辅助，非选股门槛）
        "in_red_zone": in_red_zone,
        # 金钻起涨 参数
        "xg2_hit": xg2_hit,
        "is_yang": is_yang,
        "pct_chg": round(pct_chg, 2),
        "dy2": round(dy2, 6),
        "ma5": round(ma5_val, 2),
        "ma60": round(ma60_val, 2),
        "golden_trend": round(gt_val, 2),
        "golden_bull": round(gb_val, 2),
        "golden_bull2": round(gt2_val, 2),
        "ddx_pct_last": round(float(ddx_pct.iloc[-1]), 4),
        "v2_last": round(float(v2[-1]), 6),
        # 买入 参数
        "xg_hit": xg_hit,
        "gt_above_high": gt_above_high,
        "low_touch_gt": low_touch_gt,
        "callback_buy": callback_buy,
        "var23_last": round(var_last, 4),
        "var23_prev": round(var_prev, 4),
        "llv2_llv7_eq": abs(llv2 - llv7) < 1e-8,
        "count_var23_neg_2": count_var23_neg_2,
        "cross_var23_ma2": cross_var23_ma2,
        # 红区黄柱（辅助信号）
        "hz_streak": hz_streak,
        "hz_window_run": hz_window_run,
        "hz_window": HZ_WINDOW,
        "hz_min": HZ_MIN,
        "hz_recent_ok": hz_recent_ok,
        "red_zone_hz_days": red_zone_hz_days,
        # 基础行情
        "close": round(c, 2),
        "high": round(h, 2),
        "low": round(l, 2),
    }

    return result_signal, detail


# ─── 6. 四量图计算（通达信源码移植） ──────────────────────────
def compute_four_volume(df: pd.DataFrame) -> Dict:
    """
    计算通达信四量图四大主力资金指标，用于展示机构/散户/游资/主力动向。

    指标详解（均基于通达信源码）:
      1. 机构（牛线1 — 加权20周期MID9均线）:
         MID9  = (3*C + L + O + H) / 6              — 收盘加权的典型价格
         牛线1 = Σ(W_i * MID9_i) / ΣW_i               — 20日线性递减加权均
         马线1 = MA(牛线1, 6)                         — 牛线1的6日均线平滑
         机构红: C > 牛线1                             — 价格站上加权均线

      2. 散户（GB1 — 价格偏离 + 换手率差）:
         MID1  = (3*C + L + O + H) / 6               — 同上
         牛线   = 同牛线1算法（使用MID1）               — 价格基准线
         GB    = C - 牛线                             — 价格偏离度
         换手   = V * 100 / CAPITAL                    — 换手率（需流通股本; 缺失时用成交量占比替代）
         主     = MA(换手, 5)
         大     = MA(换手, 12)
         中     = MA(换手, 34)
         散     = MA(换手, 55)
         GBB   = 主 - 散                              — 短期vs长期换手差
         GB1   = GB + GBB                             — 综合偏离

      3. 游资（W2 — 量价协同强度）:
         Q     = EMA(V, 5)
         Q1    = EMA(V, 50)
         OBV   = 累积能量潮
         OBV1  = EMA(OBV, 5)
         OBV2  = EMA(OBV, 50)
         W     = (Q - Q1) * 0.00001                    — 短期量能差
         W1    = (OBV1 - OBV2) * 0.000001              — OBV趋势差
         W2    = W + W1

      4. 主力（V6 — 趋势动能 + 加速度）:
         MID   = (3*C + L + O + H) / 6               — 同上
         DKX   = 同牛线1算法（使用MID）                — 多空线
         MADKX = MA(DKX, 6)                           — 慢速线
         MDD   = (DKX - MADKX) * 1.2                   — 趋势强弱
         V1    = (C*2 + H + L) / 4 * 10               — 重心价
         V2    = EMA(V1, 6) - EMA(V1, 55)              — 短长动能差
         V3    = EMA(V2, 6)                           — 动能平滑
         V5    = (V2 - V3) * 0.06                      — 动能加速度
         V6    = MDD + V5                              — 主力资金综合

    Returns:
        dict with keys:
          - institution: 机构信号值序列（正值=红色看多）
          - retail: 散户信号值序列（正值=红色）
          - hot_money: 游资信号值序列（正值=红色）
          - main_force: 主力信号值序列（正值=红色）
          - niuxian1: 牛线1序列（机构基准线）
          - maxian1: 马线1序列
          - inst_red_now: 当日机构是否红色
          - last_N_dates: 最近N日的日期列表（供图表x轴）
    """
    close = df["close"].values.astype(float)
    open_p = df["open"].values.astype(float)
    high = df["high"].values.astype(float)
    low = df["low"].values.astype(float)
    vol = df.get("volume", df.get("vol", pd.Series([1.0] * len(close)))).values.astype(float)

    n = len(close)
    if n < 70:
        return {"error": "数据不足70日"}

    dates = [str(d)[:10] for d in df.index]

    # ── 1. 机构 ─────────────────────────────────────────
    mid9 = (3*close + low + open_p + high) / 6.0
    niuxian1 = weighted_ma_20(mid9)
    maxian1 = pd.Series(niuxian1).rolling(6).mean().values

    institution = np.where(close > niuxian1, 1.0, np.where(close < maxian1, -1.0, -1.0))

    # ── 2. 散户 ─────────────────────────────────────────
    mid1 = (3*close + low + open_p + high) / 6.0  # same as mid9
    niuxian_retail = weighted_ma_20(mid1)
    gb = close - niuxian_retail

    # 换手率近似: 成交量/总股本(未知时用成交量自身平滑归一化)
    capital = df.get("capital", df.get("totals", None))
    if capital is not None:
        hsl = vol * 100.0 / capital.values.astype(float)
    else:
        # 无流通股本时用成交量归一化
        hsl_avg = pd.Series(vol).rolling(55).mean().values
        hsl_avg = np.where(hsl_avg > 0, hsl_avg, 1.0)
        hsl = vol / hsl_avg * 5.0  # 估算换手率~5%

    zhu_ret = pd.Series(hsl).rolling(5).mean().values
    da_ret = pd.Series(hsl).rolling(12).mean().values
    zhong_ret = pd.Series(hsl).rolling(34).mean().values
    san_ret = pd.Series(hsl).rolling(55).mean().values

    gbb = zhu_ret - san_ret
    gb1 = gb + gbb
    retail = np.where(gb1 >= 0, 1.0, -1.0)

    # ── 3. 游资 ─────────────────────────────────────────
    q_ema = compute_ema(pd.Series(vol), 5).values
    q1_ema = compute_ema(pd.Series(vol), 50).values
    w = (q_ema - q1_ema) * 0.00001

    # OBV
    obv = np.zeros(n)
    for i in range(1, n):
        if close[i] > close[i-1]:
            obv[i] = obv[i-1] + vol[i]
        elif close[i] < close[i-1]:
            obv[i] = obv[i-1] - vol[i]
        else:
            obv[i] = obv[i-1]
    obv1_ema = compute_ema(pd.Series(obv), 5).values
    obv2_ema = compute_ema(pd.Series(obv), 50).values
    w1 = (obv1_ema - obv2_ema) * 0.000001
    w2 = w + w1
    hot_money = np.where(w2 >= 0, 1.0, -1.0)

    # ── 4. 主力 ─────────────────────────────────────────
    mid_main = (3*close + low + open_p + high) / 6.0
    dkx = weighted_ma_20(mid_main)
    madkx = pd.Series(dkx).rolling(6).mean().values
    mdd = (dkx - madkx) * 1.2

    v1 = (close*2 + high + low) / 4.0 * 10
    v2_raw = compute_ema(pd.Series(v1), 6).values - compute_ema(pd.Series(v1), 55).values
    v3_raw = compute_ema(pd.Series(v2_raw), 6).values
    v5 = (v2_raw - v3_raw) * 0.06
    v6 = mdd + v5
    main_force = np.where(v6 >= 0, 1.0, -1.0)

    # 当日机构变红判断
    inst_red_now = bool(institution[-1] > 0)

    # 取最近50日供图表渲染
    preview_n = min(50, n)
    result = {
        "inst_red_now": inst_red_now,
        "niuxian1_last": round(float(niuxian1[-1]), 2),
        "maxian1_last": round(float(maxian1[-1]), 2) if not np.isnan(maxian1[-1]) else None,
        "institution": institution[-preview_n:].tolist(),
        "retail": retail[-preview_n:].tolist(),
        "hot_money": hot_money[-preview_n:].tolist(),
        "main_force": main_force[-preview_n:].tolist(),
        "dates": dates[-preview_n:],
        "niuxian1_series": np.round(niuxian1[-preview_n:], 2).tolist(),
        "maxian1_series": np.round(maxian1[-preview_n:], 2).tolist(),
        "close_series": np.round(close[-preview_n:], 2).tolist(),
    }
    return result


# ─── 6b. 机构变红检测（基于通达信四量图逻辑） ─────────────────
def check_institutional_red(df: pd.DataFrame) -> Tuple[bool, Dict]:
    """
    机构变红检测 — 基于通达信四量图核心逻辑。

    算法：
      MID9  = (3*C + L + O + H) / 6       — 收盘加权典型价格
      牛线1 = 20日线性递减加权平均(MID9)    — 机构持仓成本线
      机构变红条件: C > 牛线1

    与旧版(C > EMA20)相比：
      - 牛线1使用加权典型价格(MID9)而非简单收盘价
      - 20日权重线性递减（最近日期权重20，最远权重1）
      - 对收盘价变化更敏感，假信号更少

    Returns:
        (is_red, detail)
    """
    close = df["close"]
    high = df["high"]
    low = df["low"]
    open_p = df["open"]

    if len(close) < 30:
        return False, {"reason": "数据不足"}

    # 计算 MID9/牛线1（复用向量化加权均线，避免重复 Python 循环）
    mid9 = (3*close + low + open_p + high) / 6.0
    niuxian1_arr = weighted_ma_20(mid9.values.astype(float))
    c = float(close.iloc[-1])
    nl1 = float(niuxian1_arr[-1])
    is_red = c > nl1

    # 附加：简单 EMA20 对比（兼容旧数据展示）
    ema20_val = float(compute_ema(close, 20).iloc[-1])

    return is_red, {
        "close": round(c, 2),
        "niuxian1": round(nl1, 2),
        "ema20": round(ema20_val, 2),
        "mid9": round(float(mid9.iloc[-1]), 2),
        "above_niuxian": is_red,
    }


# ─── 6b. 老鸭头形态检测（新增·第六信号） ──────────────────────
def check_old_duck_head(df: pd.DataFrame) -> Tuple[bool, Dict]:
    """
    老鸭头形态检测 — 经典上涨中继形态，形似鸭头侧面轮廓。

    形态结构：
      1. 鸭嘴形成：MA5上穿MA10（金叉），且当时两者在MA60上方（处于上涨趋势中）
      2. 鸭头下弯：金叉后MA5到达局部高点后回落（鸭颈下弯），但回调期间MA5不破MA60
      3. 鸭翅展开：MA5重新拐头向上（当前MA5 > 前日MA5），或MA5重新上穿MA10
      4. 缩量回踩：回调期间成交量较金叉前萎缩（主力洗盘特征）

    判定逻辑（最优近似）：
      - 搜寻近20日内的MA5/MA10金叉点
      - 确认金叉时MA10 > MA60（大趋势向上）
      - 找金叉后MA5的峰值，确认峰值后有回调
      - 回调期间MA5始终在MA60上方（鸭颈不破）
      - 当前MA5拐头向上或重新金叉（鸭翅展开）
      - 缩量为加分项（不强制要求）

    Returns:
        (is_duck_head, detail)
    """
    close = df["close"]
    vol = df.get("volume", df.get("vol", pd.Series([1.0] * len(close))))

    if len(close) < 70:
        return False, {"reason": "数据不足70日"}

    ma5 = close.rolling(5).mean()
    ma10 = close.rolling(10).mean()
    ma60 = close.rolling(60).mean()

    # 1. 搜寻近12日内MA5上穿MA10且MA10>MA60的金叉点（缩短窗口，确保形态近期启动）
    lookback = min(12, len(close) - 10)
    cross_indices = []
    for i in range(-lookback, -2):
        if ma5.iloc[i - 1] <= ma10.iloc[i - 1] and ma5.iloc[i] > ma10.iloc[i]:
            if ma10.iloc[i] > ma60.iloc[i]:
                cross_indices.append(i)

    if not cross_indices:
        return False, {"reason": "近12日无符合条件的MA5/MA10金叉", "cross_found": False}

    cross_idx = cross_indices[-1]

    # 2. 鸭头下弯：金叉后MA5先涨后跌（形成峰值）
    post_cross_ma5 = ma5.iloc[cross_idx:]
    if len(post_cross_ma5) < 4:
        return False, {"reason": "金叉后数据不足"}

    peak_offset = post_cross_ma5.values.argmax()
    peak_pos = cross_idx + peak_offset
    current_pos = len(ma5) - 1

    # 峰值必须在金叉之后、当前之前（至少间隔2天）
    if peak_pos <= cross_idx or peak_pos >= current_pos - 1:
        return False, {"reason": "MA5未形成明显峰值（鸭头未下弯）"}

    # 3. 回调期间MA5不破MA60（鸭颈不破）
    pullback_ma5 = ma5.iloc[peak_pos:current_pos + 1]
    pullback_ma60 = ma60.iloc[peak_pos:current_pos + 1]
    if (pullback_ma5 < pullback_ma60).any():
        return False, {"reason": "回调期间MA5跌破MA60（鸭颈已破）"}

    # 4. 鸭翅展开：MA5必须在最新一日拐头向上（更严格）
    ma5_turning_up = bool(ma5.iloc[-1] > ma5.iloc[-2])

    if not ma5_turning_up:
        return False, {"reason": "MA5未在最新一日拐头向上（鸭翅未展开）"}

    # 5. 缩量回踩（从加分项改为必须项——洗盘核心特征）
    pullback_vol = float(vol.iloc[peak_pos:current_pos + 1].mean())
    pre_cross_vol = float(vol.iloc[max(0, cross_idx - 10):cross_idx].mean()) if cross_idx >= 10 else float(vol.iloc[:cross_idx].mean())
    vol_shrink = pullback_vol < pre_cross_vol * 0.85 if pre_cross_vol > 0 else False

    if not vol_shrink:
        return False, {"reason": "回调期间未缩量（非洗盘特征）", "pullback_vol_ratio": round(pullback_vol / max(pre_cross_vol, 1), 2)}

    # 6. 回调天数须≥3日（确保鸭头形态完整）
    if current_pos - peak_pos < 3:
        return False, {"reason": "回调天数不足3日（鸭头形态不完整）"}

    is_duck = True
    return is_duck, {
        "cross_price": round(float(close.iloc[cross_idx]), 2),
        "peak_price": round(float(close.iloc[peak_pos]), 2),
        "ma5": round(float(ma5.iloc[-1]), 2),
        "ma10": round(float(ma10.iloc[-1]), 2),
        "ma60": round(float(ma60.iloc[-1]), 2),
        "ma5_turning_up": ma5_turning_up,
        "vol_shrink": vol_shrink,
        "pullback_days": current_pos - peak_pos,
    }


# ─── 6d. 强势股检测 ─────────────────────────────────────────────
def detect_strong_stock(df: pd.DataFrame) -> Tuple[bool, Dict]:
    """
    检测强势股信号。

    条件（满足其一即可）：
      1. 阳线放量>2%：当日收阳（close>open）且成交量较昨日放大>2%
      2. 突破20日高点且收盘>EMA20中线：当日最高价突破近20日高点，且收盘价>EMA20

    Returns:
        (is_strong, detail)
    """
    close = df["close"]
    volume = df["volume"]
    high = df["high"]
    open_price = df["open"]

    if len(close) < 20:
        return False, {"reason": "数据不足（需≥20日K线）"}

    # 条件1：阳线放量>2%
    today_close = float(close.iloc[-1])
    today_open = float(open_price.iloc[-1])
    today_volume = float(volume.iloc[-1])
    prev_volume = float(volume.iloc[-2])

    yangxian = today_close > today_open
    fangliang = today_volume > prev_volume * 1.02
    cond1 = yangxian and fangliang

    # 条件2：突破20日高点且收盘>EMA20
    high_20d = float(high.iloc[-21:-1].max())
    today_high = float(high.iloc[-1])
    ema20 = float(compute_ema(close, 20).iloc[-1])

    breakout = today_high > high_20d
    above_ema20 = today_close > ema20
    cond2 = breakout and above_ema20

    is_strong = cond1 or cond2

    detail = {
        "yangxian": yangxian,
        "fangliang": fangliang,
        "cond1": cond1,
        "high_20d": high_20d,
        "today_high": today_high,
        "breakout": breakout,
        "ema20": ema20,
        "above_ema20": above_ema20,
        "cond2": cond2,
    }

    return is_strong, detail


# ─── 6c. 目标止盈价计算 ───────────────────────────────────────
def compute_target_prices(df: pd.DataFrame) -> Dict:
    """
    预判目标止盈价（三档）基于多重技术位综合判定。

    算法：
      1. 短期目标(保守)：近20日最高价 与 ATR×2+当前价 的最大值
      2. 中期目标(中性)：近60日最高价 与 当前价×1.10 的最大值
      3. 强势目标(乐观)：近120日最高价 与 Fibonacci 161.8%延伸位 的最大值

    止损参考：
      - 止损价 = 近20日最低价 与 当前价 - ATR×1.5 的最小值
      - 不破支撑时继续持有

    Returns:
        target_prices 字典，含 current/atr14/short_term/mid_term/aggressive/stop_loss
    """
    close = df["close"]
    high = df["high"]
    low = df["low"]

    current_price = float(close.iloc[-1])

    # ATR(14) — Average True Range
    trs = []
    for i in range(1, len(close)):
        h = float(high.iloc[i])
        l = float(low.iloc[i])
        pc = float(close.iloc[i - 1])
        tr = max(h - l, abs(h - pc), abs(l - pc))
        trs.append(tr)

    atr14 = float(np.mean(trs[-14:])) if len(trs) >= 14 else float(np.mean(trs))

    # 1. 短期目标（保守）
    hhv20 = float(high.iloc[-20:].max()) if len(high) >= 20 else current_price * 1.05
    st_target = max(hhv20, current_price + atr14 * 2)

    # 2. 中期目标（中性）
    hhv60 = float(high.iloc[-60:].max()) if len(high) >= 60 else current_price * 1.10
    mt_target = max(hhv60, current_price * 1.10)

    # 3. 强势目标（乐观）— Fibonacci 161.8%延伸 + 120日高点
    llv60 = float(low.iloc[-60:].min()) if len(low) >= 60 else float(low.min())
    fib_ext = current_price + (current_price - llv60) * 0.618

    hhv120 = float(high.iloc[-120:].max()) if len(high) >= 120 else mt_target
    ag_target = max(hhv120, fib_ext, current_price * 1.15)

    # 止损参考
    llv20 = float(low.iloc[-20:].min()) if len(low) >= 20 else current_price * 0.95
    stop_loss = min(llv20, current_price - atr14 * 1.5)

    # 计算各档涨幅百分比
    st_pct = round((st_target / current_price - 1) * 100, 1)
    mt_pct = round((mt_target / current_price - 1) * 100, 1)
    ag_pct = round((ag_target / current_price - 1) * 100, 1)
    sl_pct = round((stop_loss / current_price - 1) * 100, 1)

    return {
        "current": round(current_price, 2),
        "atr14": round(atr14, 2),
        "short_term": {"price": round(st_target, 2), "pct": st_pct, "label": "短期"},
        "mid_term": {"price": round(mt_target, 2), "pct": mt_pct, "label": "中期"},
        "aggressive": {"price": round(ag_target, 2), "pct": ag_pct, "label": "强势"},
        "stop_loss": {"price": round(stop_loss, 2), "pct": sl_pct, "label": "止损"},
    }


# ─── 7. 综合评分系统（v2 七信号体系） ─────────────────────────
def compute_comprehensive_score(
    df: pd.DataFrame,
    ema_score: int,
    chan_buy: bool,
    golden_diamond: str,
    inst_red: bool,
    uptrend: bool,
    old_duck_head: bool,
    strong_stock: bool,  # 新增：强势股
) -> Dict:
    """
    计算综合评分（六信号体系，满分约120+）。
    
    基础分（6个主信号 × 15分 = 90分）：
      - 缠论买字：15分
      - 金钻起涨：18分 / 买入：16分 / 红区黄柱连续(自最新日向前≥3连续且结束于当日)：16~18分
      - 机构变红：15分
      - 上涨趋势：15分
      - 老鸭头形态：15分
      - 强势股：15分
    
    EMA趋势作为必要条件：
      - ema_score >= 5（7组中至少5组上升）→ 其他信号才计入评分
      - ema_score == 7（完美趋势）→ 额外+15分
      - ema_score 5-6 → 额外+10分
    
    增强因子：
      - 动量奖励：20日涨幅20%~35% → +3
      - 强势动量：20日涨幅35%~50% → +5
      - 过热惩罚：20日涨幅>50% → -5
      - RSI过热：RSI(14)>70 → -5
      - RSI超卖：RSI(14)<30 → +3
    
    信号等级（按活跃信号数 0-6）：
      6 → 六六大顺 | 5 → 五福同享
      4 → 四喜临门 | 3 → 三线共振 | 2 → 双线 | 1 → 单信号
    
    Returns:
        score详情字典
    """
    close = df["close"]

    base_score = 0
    signals_triggered = []

    # EMA趋势作为必要条件：只有ema_score >= 5时，其他信号才计入评分
    ema_strong = ema_score >= 5
    
    if ema_strong:
        if chan_buy:
            base_score += 15
            signals_triggered.append("缠论买字")
        # 金钻信号评分（TDX严格逻辑）
        if golden_diamond:
            if golden_diamond == "金钻起涨":
                base_score += 18
                signals_triggered.append("金钻起涨")
            elif golden_diamond == "买入":
                base_score += 16
                signals_triggered.append("金钻买入")
            elif golden_diamond.startswith("红区黄柱连续"):
                try:
                    n_days = int(golden_diamond.replace("红区黄柱连续", "").replace("日", ""))
                except:
                    n_days = 3
                # 严格模式(结束于当日)触发：3日=16分，4日=17分，5日及以上=18分
                score_map = {3: 16, 4: 17}
                pts = score_map.get(n_days, 18 if n_days >= 5 else 10)
                base_score += pts
                signals_triggered.append(f"红区黄柱连续{n_days}日")
        if inst_red:
            base_score += 15
            signals_triggered.append("机构变红")
        if uptrend:
            base_score += 15
            signals_triggered.append("上涨趋势")
        if old_duck_head:
            base_score += 15
            signals_triggered.append("老鸭头形态")
        # 强势股评分
        if strong_stock:
            base_score += 15
            signals_triggered.append("强势股")
    
    # EMA趋势加分（无论其他信号是否触发，EMA趋势本身都加分）
    if ema_strong:
        if ema_score == 7:  # 完美趋势
            base_score += 15
        else:  # 5或6组EMA上升
            base_score += 10

    # 增强因子
    bonus = 0
    bonus_details = []

    if len(close) >= 20:
        ret_20d = float((close.iloc[-1] / close.iloc[-20] - 1) * 100)
        if 20 <= ret_20d <= 35:
            bonus += 3
            bonus_details.append({"factor": "动量奖励", "points": 3, "value": f"{ret_20d:.1f}%"})
        elif 35 < ret_20d <= 50:
            bonus += 5
            bonus_details.append({"factor": "强势动量", "points": 5, "value": f"{ret_20d:.1f}%"})
        elif ret_20d > 50:
            bonus -= 5
            bonus_details.append({"factor": "过热惩罚", "points": -5, "value": f"{ret_20d:.1f}%"})
    else:
        ret_20d = None

    # RSI
    if len(close) >= 14:
        rsi = float(compute_rsi(close, 14).iloc[-1])
        if rsi > 70:
            bonus -= 5
            bonus_details.append({"factor": "RSI过热", "points": -5, "value": f"RSI={rsi:.1f}"})
        elif rsi < 30:
            bonus += 3
            bonus_details.append({"factor": "RSI超卖", "points": 3, "value": f"RSI={rsi:.1f}"})
    else:
        rsi = None

    total_score = base_score + bonus

    # 信号等级（0-5，EMA不作为独立信号计数）
    # 计算除EMA趋势外的信号数
    signal_count = len([s for s in signals_triggered if not s.startswith("EMA")])
    grade_map = {
        7: "七剑天山",
        6: "六六大顺",
        5: "五福同享",
        4: "四喜临门",
        3: "三线共振",
        2: "双线",
        1: "单信号",
        0: "无信号",
    }
    grade = grade_map.get(signal_count, "无信号")
    
    # 如果EMA完美趋势且信号数>=3，额外标注
    if ema_score == 7 and signal_count >= 3:
        grade = "🏆 " + grade + " (EMA完美)"

    return {
        "total_score": total_score,
        "base_score": base_score,
        "bonus": bonus,
        "grade": grade,
        "signals": signals_triggered,
        "signal_count": signal_count,
        "ema_score": ema_score,
        "ema_strong": ema_strong,
        "rsi": round(rsi, 1) if rsi is not None else None,
        "ret_20d": round(ret_20d, 1) if ret_20d is not None else None,
        "bonus_details": bonus_details,
    }


# ─── 8. 单只股票全信号分析 ───────────────────────────────────
def analyze_stock(df: pd.DataFrame, code: str, name: str, market: str, industry: Dict = None, compute_fv: bool = False) -> Dict:
    """
    对单只股票执行全维度信号分析。

    Args:
        df: OHLCV DataFrame，index为日期，列包含 open/high/low/close/volume
        code: 股票代码
        name: 股票名称
        market: 市场（主板/创业板/科创板/港股）
        industry: 行业分类字典 {level1: str, level2: str, level3: str} 可选

    Returns:
        完整的信号分析结果字典
    """
    if df.empty or len(df) < 60:
        return {
            "code": code,
            "name": name,
            "market": market,
            "error": "数据不足（需≥60日K线）",
            "has_data": False,
        }

    result = {"code": code, "name": name, "market": market, "has_data": True}

    # 行业分类（如果提供）
    if industry:
        result["industry"] = industry

    # EMA趋势评分
    ema_score, ema_groups, ema_detail = compute_ema_trend_score(df)
    result["ema_score"] = ema_score
    result["ema_groups"] = ema_groups
    result["ema_detail"] = ema_detail

    # EMA 强趋势（>=5/7）是缠论/金钻信号计入评分的必要条件。
    # 这两类检测含 O(n²) 分型循环 / XMA 多重循环，是单只耗时主因；
    # 非强趋势下它们永远不会贡献信号分，故在此安全跳过，大幅缩短全量运行。
    ema_strong = ema_score >= 5

    # 上涨趋势（MA 向量化，开销小，保留）
    uptrend, ut_detail = check_ma_bullish_alignment(df)
    result["uptrend"] = uptrend
    result["uptrend_detail"] = ut_detail

    # 缠论买字（仅 EMA 强趋势时计算）
    if ema_strong:
        chan_buy, chan_detail = check_chan_buy_signal(df)
    else:
        chan_buy, chan_detail = False, {"reason": "EMA 趋势未达强趋势(>=5/7)，缠论买点不计入评分", "skipped": True}
    result["chan_buy"] = chan_buy
    result["chan_detail"] = chan_detail

    # 金钻信号（始终计算，不再受 EMA 强趋势门控）
    # 用户明确定义(2026-07-10): 只需要「红区黄柱连续Nd日」这一种信号，
    # 判定条件独立于 EMA 趋势强度。
    gd_type, gd_detail = check_golden_diamond(df)
    result["golden_diamond"] = gd_type
    result["golden_diamond_detail"] = gd_detail

    # 机构变红（基于四量图牛线1逻辑，向量化，保留）
    inst_red, inst_detail = check_institutional_red(df)
    result["inst_red"] = inst_red
    result["inst_detail"] = inst_detail

    # 四量图数据（供前端渲染机构/散户/游资/主力四层柱状图）
    # 不参与评分，仅前端展示。默认不在全量热循环中计算；
    # 由 data_pipeline 对"展示价值高"的候选股（评分前N / 信号>=2）懒加载，
    # 避免对全部 800 只每只都做 O(n) 四量计算。
    if compute_fv:
        result["four_volume"] = compute_four_volume(df)

    # 老鸭头形态（新增）
    duck_head, duck_detail = check_old_duck_head(df)
    result["old_duck_head"] = duck_head
    result["duck_detail"] = duck_detail

    # 强势股检测（新增）
    strong_stock, strong_detail = detect_strong_stock(df)
    result["strong_stock"] = strong_stock
    result["strong_detail"] = strong_detail

    # 综合评分（六大信号体系）
    score = compute_comprehensive_score(
        df, ema_score, chan_buy, gd_type, inst_red, uptrend, duck_head, strong_stock
    )
    result["score"] = score

    # 目标止盈价（新增）
    target_prices = compute_target_prices(df)
    result["target_prices"] = target_prices

    # K线预览数据（最近50日OHLC，供前端迷你图使用）
    preview_len = min(50, len(df))
    kline_preview = []
    for idx in range(-preview_len, 0):
        kline_preview.append({
            "d": str(df.index[idx])[:10],
            "o": round(float(df["open"].iloc[idx]), 2),
            "c": round(float(df["close"].iloc[idx]), 2),
            "l": round(float(df["low"].iloc[idx]), 2),
            "h": round(float(df["high"].iloc[idx]), 2),
        })
    result["kline_preview"] = kline_preview

    # 基础行情数据
    close = df["close"]
    vol = df.get("volume", df.get("vol", pd.Series([0] * len(close))))
    result["close"] = round(float(close.iloc[-1]), 2)
    result["change_pct"] = round(float((close.iloc[-1] / close.iloc[-2] - 1) * 100), 2) if len(close) >= 2 else None
    result["volume"] = round(float(vol.iloc[-1]), 0)
    result["high"] = round(float(df["high"].iloc[-1]), 2)
    result["low"] = round(float(df["low"].iloc[-1]), 2)
    result["date"] = str(df.index[-1])[:10] if hasattr(df.index, "__getitem__") else ""

    return result


# ─── 9. 批量分析 ──────────────────────────────────────────────
def batch_analyze(stocks_data: Dict[str, Dict]) -> List[Dict]:
    """
    批量分析多只股票。

    Args:
        stocks_data: {code: {"df": DataFrame, "name": str, "market": str}}

    Returns:
        按综合评分降序排列的分析结果列表
    """
    results = []
    for code, info in stocks_data.items():
        r = analyze_stock(info["df"], code, info["name"], info["market"])
        results.append(r)

    # 按综合评分降序排列
    results.sort(key=lambda x: x.get("score", {}).get("total_score", 0) if x.get("has_data") else 0, reverse=True)
    return results


# ─── 10. CLI 入口 ─────────────────────────────────────────────
if __name__ == "__main__":
    """
    测试用例：用内置示例数据验证信号引擎。
    """
    import json

    # 生成模拟数据用于测试
    np.random.seed(42)
    dates = pd.date_range(end="2026-06-26", periods=400, freq="B")
    price = 20 + np.cumsum(np.random.randn(400) * 0.5)
    price = np.maximum(price, 5)

    test_df = pd.DataFrame({
        "open": price * (1 + np.random.randn(400) * 0.005),
        "high": price * (1 + np.abs(np.random.randn(400) * 0.01)),
        "low": price * (1 - np.abs(np.random.randn(400) * 0.01)),
        "close": price,
        "volume": np.random.randint(1000000, 50000000, 400),
    }, index=dates)

    # 让最后一段呈上升趋势
    trend = np.linspace(0, 3, 30)
    test_df.loc[test_df.index[-30:], "close"] = price[-30:] + trend
    test_df.loc[test_df.index[-30:], "open"] = test_df.loc[test_df.index[-30:], "close"] * 0.98
    test_df.loc[test_df.index[-30:], "high"] = test_df.loc[test_df.index[-30:], "close"] * 1.02
    test_df.loc[test_df.index[-30:], "low"] = test_df.loc[test_df.index[-30:], "close"] * 0.97

    result = analyze_stock(test_df, "sz_000001", "测试股票", "主板")
    print(json.dumps(result, ensure_ascii=False, indent=2, default=str))
